{
  "name": "fusion-vue-tailwind-starter",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p --npm-path bun type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "~10.2.0",
    "jiti": "^2.7.0",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.15",
    "prettier": "3.5.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^7.3.6",
    "vite-plugin-vue-devtools": "^7.7.10",
    "vitest": "^3.2.6",
    "vue-tsc": "^2.2.12"
  }
}
